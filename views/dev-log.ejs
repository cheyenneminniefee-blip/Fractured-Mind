    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fractured Mind // Developer Log</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        body { background-color: #0d0e12; color: #d1d5db; font-family: monospace; padding: 20px; line-height: 1.6; }
        .dev-container { max-width: 800px; margin: 0 auto; }

        nav { margin-bottom: 30px; }
        .btn-back { color: #a78bfa; text-decoration: none; border: 1px solid #a78bfa; padding: 6px 12px; border-radius: 4px; font-weight: bold; transition: all 0.2s; }
        .btn-back:hover { background: #a78bfa; color: #0d0e12; }

        header { border-bottom: 2px solid #2e3244; padding-bottom: 20px; margin-bottom: 30px; }
        h1 { color: #a78bfa; margin: 0 0 10px 0; font-size: 2rem; text-transform: uppercase; letter-spacing: 0.05em; }
        .subtitle { color: #9ca3af; font-size: 1.1rem; margin: 0; }

        /* The Reusable Checkpoint Card */
        .checkpoint-card { background: #1a1c23; border: 1px solid #2e3244; border-left: 4px solid #4338ca; border-radius: 6px; padding: 25px; margin-bottom: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.3); transition: transform 0.2s; }
        .checkpoint-card:hover { transform: translateX(5px); border-left-color: #a78bfa; }

        .card-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 15px; border-bottom: 1px solid #2e3244; padding-bottom: 10px; }
        .checkpoint-title { color: #f3f4f6; font-size: 1.3rem; margin: 0; font-weight: bold; }
        .checkpoint-date { color: #34d399; font-size: 0.9rem; }

        .checkpoint-desc { color: #d1d5db; margin-bottom: 20px; }

        .github-link { display: inline-block; background: #3730a3; color: white; text-decoration: none; padding: 8px 16px; border-radius: 4px; font-weight: bold; font-size: 0.9rem; transition: background 0.2s; }
        .github-link:hover { background: #4f46e5; }
    </style>
</head>
