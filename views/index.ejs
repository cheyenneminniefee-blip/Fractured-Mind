<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fractured Mind - Home</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <header class="game-intro">
        <% if (typeof announcementText !== 'undefined' && announcementText !== '') { %>
            <div style="background-color: #3730a3; color: white; text-align: center; padding: 10px; font-weight: bold; border-top: 1px solid #4f46e5; border-bottom: 1px solid #4f46e5;">
                [SYSTEM ANNOUNCEMENT]: <%= announcementText %>
            </div>
        <% } %>
        <h1>Fractured Mind</h1>
        <p class="summary">An atmospheric, narrative-driven 2D platformer where you navigate fragmented memories, seal reality anomalies, and repair a shattered psyche.</p>
    </header>
    <main class="auth-container">
        <section class="login-box">
            <h2>Access Persona</h2>
            <form action="/auth/login" method="POST">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" autocomplete="username" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" autocomplete="current-password" required>
                </div>
                <button type="submit" class="btn-submit">Synchronize Mind</button>
            </form>
            <p class="redirect-text">New to the rift? <a href="/register">Create a profile here</a>.</p>
        </section>
    </main>
            <footer style="text-align: center; margin-top: 40px; padding: 20px; border-top: 1px solid #333;">
                <a href="/leaderboard" style="color: #a78bfa; text-decoration: none; margin: 0 15px;">🏆 Global Leaderboard</a>
                <a href="/dev-log" style="color: #a78bfa; text-decoration: none; margin: 0 15px;">📜 Developer Log</a>
            </footer>
        </body>
</html>
