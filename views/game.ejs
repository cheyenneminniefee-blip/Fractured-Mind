<div id="nav-bar">
    <div class="nav-brand">FRACTURED MIND // CORE ENGINE</div>
    <div class="nav-links">
        <a href="/game" class="active">Simulation</a>
        <a href="/leaderboard">Leaderboard</a>
        <a href="/logout">Disconnect (<%= profile.username %>)</a>
    </div>
</div>

<div id="game-container">
    <canvas id="gameCanvas"></canvas>

    <div id="ai-chat-overlay" style="display: none;">
        <div class="chat-history" id="chat-history">
            <p class="ai-text"><strong>Memory Entity:</strong> Approach, fractured one. What seeks clarity?</p>
        </div>
        <div class="chat-input-area">
            <input type="text" id="chat-input" placeholder="Transmit thought... (Press Enter to send)" autocomplete="off">
            <button id="chat-send-btn">SEND</button>
        </div>
    </div>
</div>

<style>
    body {
        margin: 0;
        padding: 0;
        background-color: #0d0d11;
        color: #ffffff;
        font-family: 'Courier New', Courier, monospace;
        display: flex;
        flex-direction: column;
        height: 100vh; /* Force body to fill exactly 100% of the browser height */
        overflow: hidden; /* Prevent accidental scrollbars */
    }

    #nav-bar {
        height: 50px; /* Precise fixed height for your navigation area */
        background-color: #16161f;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 20px;
        border-bottom: 1px solid #333344;
        box-sizing: border-box;
    }

    .nav-links a {
        color: #8888aa;
        text-decoration: none;
        margin-left: 20px;
    }

    .nav-links a.active, .nav-links a:hover {
        color: #ffffff;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
    }

    #game-container {
        flex: 1; /* Instructs this container to greedily consume all remaining vertical screen real estate */
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 15px; /* Creates that small, uniform buffer margin on the screen edges */
        box-sizing: border-box;
    }

    #gameCanvas {
        background-color: #000000;
        border: 2px solid #444455;
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.7);
    }

    /* AI Chat Overlay Styling */
    #ai-chat-overlay {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        max-width: 90%;
        background: rgba(13, 13, 17, 0.9);
        border: 1px solid #00ffcc;
        box-shadow: 0 0 20px rgba(0, 255, 204, 0.3);
        border-radius: 5px;
        padding: 15px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 100; /* Ensures it sits on top of the canvas */
    }

    .chat-history {
        height: 100px;
        overflow-y: auto;
        font-size: 14px;
        line-height: 1.4;
        color: #cccccc;
    }

    .ai-text { color: #00ffcc; text-shadow: 0 0 5px rgba(0, 255, 204, 0.5); }
    .player-text { color: #ffffff; }

    .chat-input-area { display: flex; gap: 10px; }

    #chat-input {
        flex: 1;
        background: #111;
        border: 1px solid #444;
        color: #fff;
        padding: 8px;
        font-family: inherit;
    }

    #chat-send-btn {
        background: #00ffcc;
        color: #000;
        border: none;
        padding: 8px 15px;
        cursor: pointer;
        font-weight: bold;
    }
</style>
<script>
    // 1. Safely package the server-side profile data into a global window object
    // We use <%- %> instead of <%= %> to safely output raw JSON
    window.GAME_STATE = {
        playerProfile: <%- JSON.stringify(profile) %>
    };
</script>

<script src="/js/game.js"></script>